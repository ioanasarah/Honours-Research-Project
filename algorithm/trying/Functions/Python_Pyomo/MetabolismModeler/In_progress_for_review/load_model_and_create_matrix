def load_files(
	main_files_location,
	expression_file,
	model_file,
):
	start_time = time.time()
	expression = pd.read_feather(os.path.join(main_files_location, expression_file))
	model_file = load_json_model(os.path.join(main_files_location, model_file))
	larger_df  = pd.read_excel(os.path.join(main_files_location, "larger_df.xlsx"))
	print(f'Loaded model and expression in {time.time() - start_time} seconds')
	
	return expression, model_file, larger_df

def create_larger_excel(
	main_files_location,
	sample_files_location
):
	larger_df = pd.DataFrame(columns = ["ID", "Task", "Sample"])
	task_number = 1
	for sample_number in range(1,129):
		file_name = f"filtered_Task_{task_number:03}_Sample{sample_number:03}_irr.xlsx"
		df = pd.DataFrame()
		try:
			sample_df = pd.read_excel(os.path.join(sample_files_location, file_name))
			try:
				df["ID"] = sample_df["ID"]
				df["Task"] = [task_number] * len(sample_df["ID"])
				df["Sample"] = [sample_number] * len(sample_df["ID"])
				larger_df = pd.concat([larger_df, df], axis = 0)
			except Exception as e:
				print(e)
		except:
			print(f"Could not read {os.path.join(sample_files_location, file_name)}")

	larger_df.to_excel(os.path.join(main_files_location, "larger_df.xlsx"))

