def create_co_occurence_matrix(main_files_location):
	reactions_per_sample = {}

	larger_df  = pd.read_excel(os.path.join(main_files_location, "larger_df.xlsx"))
	# Extract the first column as a list
	all_reactions_row = list(set(larger_df.iloc[:, 1].tolist()))
	all_reactions_column = list(set(larger_df.iloc[:, 1].tolist()))
	print(all_reactions_row)

	reactions_dict = {}

	for idx, row in larger_df.iterrows():
	    reaction = row[1]  # Assuming the first column is 'Reaction'
	    sample_number = row[3]    # Assuming the third column is 'Sample'

	    if sample_number not in reactions_dict:
	        reactions_dict[sample_number] = []
	    reactions_dict[sample_number].append(reaction)
	print (reactions_dict)


	#set_union_of_reactions = set.union_of_reactions
	#co_occurence_matrix = pd.DataFrame(data= set_union_of_reactions, index= set_union_of_reactions)
	co_occurence_matrix = pd.DataFrame(
		np.zeros((len(all_reactions_column), len(all_reactions_row))),
		index=all_reactions_row,
		columns=all_reactions_column
		)

	for reaction_column in all_reactions_column:
		for sample_number in reactions_dict.keys():
			if reaction_column in reactions_dict[sample_number]:
				for reaction_row in all_reactions_row:
					if reaction_row in reactions_dict[sample_number]:
						co_occurence_matrix.at[reaction_column, reaction_row] += 1
					else:
						co_occurence_matrix.at[reaction_column, reaction_row] += 0
			#else:
			#	co_occurence_matrix.at[reaction_column, reaction_row] += 0


	print(co_occurence_matrix)
	co_occurence_matrix.to_excel(os.path.join(main_files_location, "co_occurence_matrix.xlsx"))

	co_occurence_matrix_heatmap = px.imshow(co_occurence_matrix, text_auto=True)
	co_occurence_matrix_heatmap.show()

	# create co-occurence matrix by counting how often each reaction is present in total (diagnal)
	## then per reaciton see how often it is together with another



